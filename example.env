# Mu2e DAQ Resource Manager — environment configuration.
#
# Copy this file to ".env" in the project root and edit as needed:
#
#     cp example.env .env
#
# Both the shell scripts (start/stop/bootstrap) and the server read .env.
# Precedence: commandline flag > real environment variable > .env > config file > built-in default.
# A variable already exported in your shell is NOT overridden by .env.

# --- Server bind address ---------------------------------------------------
# Host/interface to bind. Use 0.0.0.0 for all interfaces.
RM_HOST=0.0.0.0
# TCP port to listen on.
RM_PORT=8080

# --- File locations --------------------------------------------------------
# By default the scripts resolve these to absolute paths under the project
# directory. Only set them to override, and prefer absolute paths: a relative
# path is resolved against the current working directory, not the project root.
#RM_CONFIG=/path/to/resources.yaml
#RM_STATE=/path/to/state.json

# --- Daemon mode -----------------------------------------------------------
# Start in the background without passing -d/--daemon: set to 1/true/yes/on.
RM_DAEMON=0
# Directory for the pidfile and log when running as a daemon.
# Defaults to <project>/run; set to override (prefer an absolute path).
#RM_RUN_DIR=/var/run/mu2edaq
# PID file path (defaults to $RM_RUN_DIR/resource-manager.pid).
#RM_PIDFILE=run/resource-manager.pid
# Daemon log file (defaults to $RM_RUN_DIR/resource-manager.log).
#RM_LOG=run/resource-manager.log
# Seconds stop_server.sh waits for graceful shutdown before SIGKILL.
RM_STOP_TIMEOUT=10

# --- Python environment (used by bootstrap.sh) -----------------------------
# Interpreter used to create the virtual environment.
#PYTHON=python3
# Virtual environment location.
#RM_VENV=venv
